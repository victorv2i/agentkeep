{
  "name": "@agentkeep/core",
  "version": "0.1.0",
  "description": "Your agent's memory, as a vault you can read: a self-hosted, Obsidian-compatible markdown vault your agent maintains through MCP.",
  "license": "MIT",
  "author": "Victor Iglesias <victoriglesiascs@gmail.com>",
  "homepage": "https://github.com/victorv2i/agentkeep#readme",
  "repository": { "type": "git", "url": "github:victorv2i/agentkeep" },
  "bugs": "https://github.com/victorv2i/agentkeep/issues",
  "keywords": [
    "agent",
    "agent-memory",
    "mcp",
    "obsidian",
    "markdown",
    "vault",
    "self-hosted",
    "knowledge-management"
  ],
  "type": "module",
  "publishConfig": { "access": "public" },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "!dist/**/*.test.*",
    "README.md",
    "LICENSE",
    "SPEC.md",
    "AGENT-ROUTINE.md",
    "docs/*.png"
  ],
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/core/index.js",
  "types": "./dist/core/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/core/index.d.ts",
      "default": "./dist/core/index.js"
    }
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "pnpm clean && tsc",
    "prepublishOnly": "pnpm build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.18.1",
    "async-mutex": "^0.5.0",
    "chokidar": "^5.0.0",
    "gray-matter": "^4.0.3",
    "minisearch": "^7.2.0",
    "proper-lockfile": "^4.1.2",
    "remark-frontmatter": "^5.0.0",
    "remark-parse": "^11.0.0",
    "simple-git": "^3.27.0",
    "unified": "^11.0.5",
    "write-file-atomic": "^6.0.0",
    "yaml": "^2.6.1",
    "zod": "3.25.76"
  },
  "bin": {
    "agentkeep-mcp": "dist/bin/agentkeep-mcp.js",
    "agentkeep": "dist/bin/agentkeep.js"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/proper-lockfile": "^4.1.4",
    "@types/write-file-atomic": "^4.0.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
